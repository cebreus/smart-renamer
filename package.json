{
  "name": "smart-renamer",
  "version": "0.1.0",
  "type": "module",
  "description": "Smart file renamer using local LLM and OCR",
  "main": "index.js",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "start": "node index.js",
    "lint": "pnpm check:lint",
    "format": "pnpm fix:format",
    "fix:format": "remark . -q && eslint . --fix && prettier . -u -l -w",
    "check:lint": "eslint . --max-warnings=0 && remark . -f -q && prettier . -u -l",
    "check:unused": "knip",
    "check:dupe": "jscpd",
    "check:deps": "depcruise index.js",
    "check:audit": "pnpm audit --prod --audit-level high",
    "review": "coderabbit review",
    "check:quality": "pnpm check:lint && pnpm check:unused && pnpm check:dupe && pnpm check:deps",
    "check:all": "pnpm check:quality && pnpm check:audit && pnpm check:review",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "pre-push": "pnpm check:all"
  },
  "lint-staged": {
    "*.{js,md,json}": "pnpm fix:format"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.5.0",
    "jscpd": "^4.0.9",
    "knip": "^6.6.3",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "remark-cli": "^12.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-lint-heading-whitespace": "^1.0.0",
    "remark-lint-no-duplicate-headings": "^4.0.1",
    "remark-preset-lint-consistent": "^6.0.1",
    "remark-preset-lint-recommended": "^7.0.1",
    "remark-preset-prettier": "^2.0.2",
    "simple-git-hooks": "^2.13.1",
    "unified": "^11.0.5"
  }
}
